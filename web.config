<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <rule name="ReverseProxyToNode" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://localhost:8668/{R:1}" />
        </rule>
      </rules>
      <outboundRules>
        <!--
          IIS ARR (server-level) bật "Reverse rewrite host in response headers" mặc định.
          Nó đổi MỌI Location header của Node.js về partner.fireant.vn, kể cả:
            - https://accounts.fireant.vn/connect/...  (IS4 OAuth redirect)
            - https://company.fireant.vn/pay...        (trang thanh toán)
          2 rule dưới phục hồi đúng host cho từng trường hợp.
          Chỉ áp dụng cho response 3xx — không ảnh hưởng response 200 hay site khác.
        -->

        <!-- Phục hồi redirect sang IS4 (accounts.fireant.vn) -->
        <rule name="FixLocationIS4" preCondition="Is3xx">
          <match serverVariable="RESPONSE_Location"
                 pattern="^https://partner\.fireant\.vn/connect/(.+)$" />
          <action type="Rewrite" value="https://accounts.fireant.vn/connect/{R:1}" />
        </rule>

        <!-- Phục hồi redirect sang trang thanh toán Corporate (company.fireant.vn) -->
        <rule name="FixLocationCompany" preCondition="Is3xx">
          <match serverVariable="RESPONSE_Location"
                 pattern="^https://partner\.fireant\.vn/pay(.*)$" />
          <action type="Rewrite" value="https://company.fireant.vn/pay{R:1}" />
        </rule>

        <preConditions>
          <preCondition name="Is3xx">
            <add input="{RESPONSE_STATUS}" pattern="^3\d\d$" />
          </preCondition>
        </preConditions>
      </outboundRules>
    </rewrite>
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="52428800" />
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
