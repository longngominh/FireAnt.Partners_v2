<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <rule name="ReverseProxyToNode" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://localhost:8668/{R:1}" />
        </rule>
      </rules>
      <outboundRules>
        <!--
          IIS ARR ở server level bật "Reverse rewrite host in response headers"
          (mặc định), làm nó đổi Location: https://accounts.fireant.vn/connect/...
          (Auth.js sinh ra để redirect sang IS4) thành https://partner.fireant.vn/...
          gây redirect loop về middleware.

          Không thể tắt global vì ảnh hưởng site khác. Rule dưới chỉ áp dụng cho
          site này: nếu Location bị rewrite về partner.fireant.vn/connect/...
          (IS4 endpoint), thì phục hồi lại accounts.fireant.vn/connect/...
        -->
        <rule name="UndoArrLocationRewriteForIS4" preCondition="IsConnectRedirect">
          <match serverVariable="RESPONSE_Location" pattern="^https://partner\.fireant\.vn/(connect/.+)$" />
          <action type="Rewrite" value="https://accounts.fireant.vn/{R:1}" />
        </rule>
        <preConditions>
          <preCondition name="IsConnectRedirect">
            <add input="{RESPONSE_STATUS}" pattern="^3\d\d$" />
            <add input="{RESPONSE_Location}" pattern="^https://partner\.fireant\.vn/connect/" />
          </preCondition>
        </preConditions>
      </outboundRules>
    </rewrite>
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="52428800" />
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
