# Public base URL of this app (used for short-link generation in QR codes)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Auth.js v5: bắt buộc khi chạy sau reverse proxy (IIS, nginx, ...).
# Nếu không set, Auth.js dùng request host/protocol → có thể là localhost:8668
# khiến callback OIDC bị sai redirect_uri.
# Trên dev có thể bỏ qua; trên production luôn đặt URL public HTTPS.
# AUTH_URL="https://partner.fireant.vn"
# AUTH_TRUST_HOST="true"

# Auth.js secret (generate: openssl rand -base64 32)
AUTH_SECRET="replace-me-with-32-chars-of-random"

# SQL Server (main FireAnt DB) connection string
# Format: sqlserver://HOST:PORT;database=DB;user=USER;password=PASS;encrypt=true;trustServerCertificate=true
DATABASE_URL="sqlserver://localhost:1433;database=FireAnt;user=sa;password=YourStrongPass!;encrypt=true;trustServerCertificate=true"
