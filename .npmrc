# pnpm strict mode mặc định không hoist transitive deps lên top-level
# node_modules/, mà giấu trong .pnpm/<pkg>@<ver>/node_modules/. Khi
# Next.js externalize mssql/tedious (serverExternalPackages), runtime
# require('debug') không resolve được vì debug nằm sâu trong .pnpm.
# shamefully-hoist=true cho pnpm install kiểu flat như npm/yarn,
# tất cả transitive deps đều accessible từ top-level node_modules.
shamefully-hoist=true
